{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "types": ["node"],
    "lib": ["ES2023", "DOM"],
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true
  },
  "include": [
    "./src/electron/**/*.ts",
    "./src/electron/**/*.d.ts",
    "./src/renderer/**/*.ts",
    "./src/renderer/**/*.tsx",
    "./src/renderer/**/*.d.ts"
  ]
}
