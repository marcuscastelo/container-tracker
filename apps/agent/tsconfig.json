{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "baseUrl": "../..",
    "paths": {
      "~/*": ["./src/*"],
      "@agent/*": ["./apps/agent/src/*"]
    },
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": false,
    "outDir": "../../dist",
    "rootDir": "../..",
    "types": ["node"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true
  },
  "include": [
    "./src/agent.ts",
    "./src/agent.scheduler.ts",
    "./src/app/agent.main.ts",
    "./src/supervisor.ts",
    "./src/core/contracts/release-runtime-handoff.contract.ts",
    "./src/release/application/activate-release.ts",
    "./src/release/application/check-for-update.ts",
    "./src/release/application/download-release.ts",
    "./src/release/application/get-current-release.ts",
    "./src/release/application/release-layout.ts",
    "./src/release/application/rollback-release.ts",
    "./src/release/application/stage-release.ts",
    "./src/release/application/verify-release-checksum.ts",
    "./src/release/domain/release-policy.ts",
    "./src/release/domain/release-state.ts",
    "./src/release/infrastructure/bundle-downloader.ts",
    "./src/release/infrastructure/bundle-extractor.ts",
    "./src/release/infrastructure/release-manifest.client.ts",
    "./src/release/infrastructure/release-state.file-repository.ts",
    "./src/runtime/application/drain-runtime.ts",
    "./src/runtime/application/restart-runtime.ts",
    "./src/runtime/application/run-health-check.ts",
    "./src/runtime/application/start-runtime.ts",
    "./src/runtime/application/stop-runtime.ts",
    "./src/runtime/application/supervise-runtime.ts",
    "./src/runtime/domain/runtime-health-policy.ts",
    "./src/runtime/domain/runtime-lifecycle.ts",
    "./src/runtime/infrastructure/pid-store.ts",
    "./src/runtime/infrastructure/process-runner.ts",
    "./src/runtime/infrastructure/runtime-health.repository.ts",
    "./src/runtime/infrastructure/runtime-stdio-log-writer.ts",
    "./src/runtime/infrastructure/supervisor-control.repository.ts",
    "./src/runtime/paths.ts",
    "./src/runtime/alias-loader.ts",
    "./src/runtime/register-alias-loader.ts",
    "./src/runtime/lifecycle-exit-codes.ts",
    "./src/pending-activity.ts",
    "./src/cli/ct-agent.ts",
    "./src/cli/ct-agent-admin.ts",
    "./src/installer/ct-agent-startup.lib.ts",
    "./src/installer/ct-agent-startup.entry.ts",
    "./src/platform/windows/startup.ts",
    "./src/build-release.ts",
    "./src/bundle-release.ts"
  ]
}
