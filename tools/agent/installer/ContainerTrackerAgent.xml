<service>
  <id>ContainerTrackerAgent</id>
  <name>Container Tracker Agent</name>
  <description>Container Tracker background sync service.</description>

  <executable>%LOCALAPPDATA%\Programs\ContainerTrackerAgent\node\node.exe</executable>
  <arguments>"%LOCALAPPDATA%\Programs\ContainerTrackerAgent\app\dist\agent.js"</arguments>
  <workingdirectory>%LOCALAPPDATA%\Programs\ContainerTrackerAgent\app</workingdirectory>
  <startmode>Automatic</startmode>

  <logpath>%LOCALAPPDATA%\ContainerTracker\logs</logpath>
  <log mode="roll-by-size-time">
    <sizeThreshold>10240</sizeThreshold>
    <pattern>yyyyMMdd</pattern>
    <autoRollAtTime>00:00:00</autoRollAtTime>
    <keepFiles>8</keepFiles>
  </log>

  <!-- DOTENV_PATH=%LOCALAPPDATA%\ContainerTracker\config.env -->
  <env name="DOTENV_PATH" value="%LOCALAPPDATA%\ContainerTracker\config.env" />

  <onfailure action="restart" delay="10 sec" />
  <onfailure action="restart" delay="30 sec" />
  <onfailure action="none" />
</service>
