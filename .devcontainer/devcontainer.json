{
  "name": "container-tracker-codex",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "remoteUser": "node",
  "workspaceFolder": "/workspaces/container-tracker",
  "runArgs": ["--init"],
  "mounts": [
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.codex,target=/home/node/.codex,type=bind,consistency=cached",
    "source=${localEnv:SSH_AUTH_SOCK},target=/ssh-agent,type=bind"
  ],
  "containerEnv": {
    "RALPH_AGENT": "codex",
    "RALPH_ALLOW_DANGEROUS_EXEC": "1",
    "SSH_AUTH_SOCK": "/ssh-agent"
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "bash .devcontainer/post-start.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
