{
  "name": "container-tracker-codex",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "args": {
      "CHROMIUM_VERSION": "145.0.7632.116-1~deb12u1"
    }
  },
  "remoteUser": "node",
  "workspaceFolder": "/workspaces/container-tracker",
  "runArgs": ["--init"],
  "mounts": [
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.codex,target=/home/node/.codex,type=bind,consistency=cached"
  ],
  "containerEnv": {
    "CHROME_PATH": "/usr/bin/chromium",
    "DEVCONTAINER": "1",
    "RALPH_AGENT": "codex",
    "RALPH_ALLOW_DANGEROUS_EXEC": "1"
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "bash .devcontainer/post-start.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
