pkgname=container-tracker-agent
pkgver=0.1.0
pkgrel=8
pkgdesc='Container Tracker headless Linux agent runtime'
arch=('x86_64')
url='https://github.com/marcuscastelo/container-tracker'
license=('MIT')
depends=('nodejs' 'systemd' 'electron')
makedepends=('typescript')
install='container-tracker-agent.install'
source=(
  'container-tracker-agent.service'
  'container-tracker-agent.sysusers'
  'container-tracker-agent.tmpfiles'
  'container-tracker-agent.launcher'
  'container-tracker-agent-ui.launcher'
  'container-tracker-agent-tray.launcher'
  'container-tracker-agent-admin.launcher'
  'container-tracker-agent-ui.desktop'
  'container-tracker-agent-tray.desktop'
  'container-tracker-agent.install'
)
sha256sums=(
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
)

_repo_root="${startdir}/../.."

run_pnpm() {
  if command -v pnpm >/dev/null 2>&1; then
    pnpm "$@"
    return $?
  fi

  if command -v corepack >/dev/null 2>&1; then
    corepack pnpm "$@"
    return $?
  fi

  echo "error: pnpm not found. Install pnpm (pacman or npm) or enable Corepack." >&2
  return 1
}

prepare() {
  local deploy_dir="${srcdir}/agent-app"
  mkdir -p "${startdir}/pkg" "${startdir}/src"
  chmod 0755 "${startdir}/pkg" "${startdir}/src" || true
  rm -rf "${deploy_dir}"
}

build() {
  local deploy_dir="${srcdir}/agent-app"
  chmod 0755 "${startdir}/pkg" "${startdir}/src" || true

  cd "${_repo_root}" || exit 1

  run_pnpm run agent:build
  run_pnpm run agent-control-ui:build
  run_pnpm --filter @container-tracker/agent deploy --legacy --prod "${deploy_dir}"
  node "${_repo_root}/scripts/agent/sync-runtime-pnpm-deps.mjs" \
    "${_repo_root}/node_modules" \
    "${deploy_dir}/node_modules"
}

package() {
  local deploy_dir="${srcdir}/agent-app"
  local install_root="${pkgdir}/usr/lib/container-tracker-agent"

  install -d "${install_root}"
  install -d "${install_root}/dist/apps/agent"
  cp -a "${_repo_root}/dist/apps/agent/src" "${install_root}/dist/apps/agent/"
  cp -a "${_repo_root}/dist/src" "${install_root}/dist/"
  cp -a "${_repo_root}/dist/apps/agent/control-ui" "${install_root}/dist/apps/agent/"
  cp -a "${deploy_dir}/node_modules" "${install_root}/node_modules"
  install -Dm644 "${_repo_root}/apps/agent/package.json" "${install_root}/package.json"
  install -Dm644 \
    "${_repo_root}/apps/agent/src/installer/bootstrap.env.template" \
    "${pkgdir}/etc/container-tracker-agent/bootstrap.env.template"
  install -Dm755 \
    "${startdir}/container-tracker-agent.launcher" \
    "${install_root}/launcher.sh"

  cat > "${install_root}/supervisor.js" <<'SHIM'
#!/usr/bin/env node
import './dist/apps/agent/src/bootstrap/supervisor-entry.js'
SHIM
  chmod 0755 "${install_root}/supervisor.js"

  install -d "${pkgdir}/usr/bin"
  cat > "${pkgdir}/usr/bin/ct-agent" <<'WRAPPER'
#!/usr/bin/env bash
install_root="/usr/lib/container-tracker-agent"
register_path="$install_root/dist/apps/agent/src/runtime/register-alias-loader.js"
agent_path="$install_root/dist/apps/agent/src/cli/ct-agent.js"

if [ -f "$register_path" ]; then
  exec /usr/bin/node --import="$register_path" "$agent_path" "$@"
fi

exec /usr/bin/node "$agent_path" "$@"
WRAPPER
  install -Dm755 \
    "${startdir}/container-tracker-agent-ui.launcher" \
    "${pkgdir}/usr/bin/ct-agent-ui"
  install -Dm755 \
    "${startdir}/container-tracker-agent-tray.launcher" \
    "${pkgdir}/usr/bin/ct-agent-tray"
  install -Dm755 \
    "${startdir}/container-tracker-agent-admin.launcher" \
    "${pkgdir}/usr/bin/ct-agent-admin"
  chmod 0755 "${pkgdir}/usr/bin/ct-agent"
  chmod 0755 "${install_root}/dist/apps/agent/src/cli/ct-agent.js"
  chmod 0755 "${install_root}/dist/apps/agent/src/cli/ct-agent-admin.js"

  install -Dm644 \
    "${startdir}/container-tracker-agent.service" \
    "${pkgdir}/usr/lib/systemd/system/container-tracker-agent.service"
  install -Dm644 \
    "${startdir}/container-tracker-agent.sysusers" \
    "${pkgdir}/usr/lib/sysusers.d/container-tracker-agent.conf"
  install -Dm644 \
    "${startdir}/container-tracker-agent.tmpfiles" \
    "${pkgdir}/usr/lib/tmpfiles.d/container-tracker-agent.conf"
  install -Dm644 \
    "${startdir}/container-tracker-agent-ui.desktop" \
    "${pkgdir}/usr/share/applications/container-tracker-agent-ui.desktop"
  install -Dm644 \
    "${startdir}/container-tracker-agent-tray.desktop" \
    "${pkgdir}/etc/xdg/autostart/container-tracker-agent-tray.desktop"
  install -Dm644 \
    "${_repo_root}/public/branding/logo-light.png" \
    "${pkgdir}/usr/share/icons/hicolor/256x256/apps/container-tracker-agent.png"
}
