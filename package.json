{
  "name": "example-with-tailwindcss",
  "type": "module",
  "imports": {
    "#container-tracker-eslint-plugin": "./scripts/eslint-plugin-container-tracker.mjs"
  },
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "initialize-worktree": "node ./scripts/initialize-worktree.mjs",
    "dev:server": "vinxi dev",
    "agent-control-ui:build:main": "pnpm --filter @container-tracker/agent run control-ui:build:main",
    "agent-control-ui:build:renderer": "pnpm --filter @container-tracker/agent run control-ui:build:renderer",
    "agent-control-ui:build": "pnpm --filter @container-tracker/agent run control-ui:build",
    "agent-control-ui:dev": "pnpm --filter @container-tracker/agent run control-ui:dev",
    "agent:ui-control:dev": "pnpm run agent-control-ui:dev",
    "agent-control-ui:start": "pnpm --filter @container-tracker/agent run control-ui:start",
    "agent-startup-launcher:build": "pnpm --filter @container-tracker/agent run startup-launcher:build",
    "build": "vinxi build",
    "start": "vinxi start",
    "build:local": "node --env-file=.env ./node_modules/vinxi/bin/cli.mjs build",
    "start:local": "node --env-file=.env ./node_modules/vinxi/bin/cli.mjs start",
    "type-check": "tsc -p tsconfig.app.json --noEmit --skipLibCheck",
    "type-check:agent": "pnpm --filter @container-tracker/agent run type-check",
    "type-check:agent-control-ui": "pnpm --filter @container-tracker/agent run type-check",
    "test": "vitest run",
    "test:silent": "node scripts/vitest-summary.mjs",
    "test:coverage": "vitest run --coverage",
    "coverage:report": "node scripts/coverage-policy-report.mjs",
    "coverage:baseline": "pnpm run test:coverage && node scripts/coverage-policy-report.mjs --write --write-baseline",
    "test:playwright": "playwright test",
    "i18n:check": "node scripts/check-i18n-keys.mjs",
    "i18n:guard": "node scripts/check-i18n-regressions.mjs",
    "i18n:enforce": "node scripts/enforce-i18n-no-hardcoded.mjs",
    "fix": "pnpm exec biome format --write . --format-with-errors true && pnpm exec biome check . --write --max-diagnostics=1000 --no-errors-on-unmatched",
    "lint": "pnpm exec biome check . --max-diagnostics=1000 --no-errors-on-unmatched && pnpm exec eslint --ext .ts,.tsx . --max-warnings=0",
    "architecture:boundary-scan": "node scripts/architecture-boundary-scan.mjs",
    "agent:boundary-scan": "node scripts/agent/agent-boundary-scan.mjs",
    "agent:smoke:config-state": "vitest run apps/agent/src/tests/agent-config.mapper.test.ts apps/agent/src/tests/state-contracts.test.ts",
    "agent:smoke:platform": "vitest run apps/agent/src/tests/runtime-paths.test.ts",
    "agent:smoke:release": "vitest run apps/agent/src/tests/release-check-cycle.test.ts apps/agent/src/tests/self-update.integration.test.ts",
    "agent:smoke:runtime": "vitest run apps/agent/src/tests/runtime-lifecycle.test.ts apps/agent/src/tests/supervisor.test.ts",
    "agent:smoke:sync": "vitest run apps/agent/src/tests/provider-runner.registry.test.ts apps/agent/src/tests/provider-runners.test.ts apps/agent/src/tests/execute-sync-job.test.ts apps/agent/src/tests/run-sync-cycle.test.ts",
    "agent:smoke": "run-s agent:smoke:config-state agent:smoke:platform agent:smoke:release agent:smoke:runtime agent:smoke:sync",
    "lint:no-iife:error-smoke": "node scripts/no-iife-in-jsx-error-smoke.mjs",
    "ui:complexity:report": "node scripts/ui-complexity-report.mjs",
    "ui:complexity:report:write": "node scripts/ui-complexity-report.mjs --write",
    "ui:complexity:lint:soft": "node scripts/ui-complexity-report.mjs",
    "ui:complexity:allowlist:check": "node scripts/ui-complexity-allowlist-check.mjs",
    "ui:complexity:ci": "pnpm run ui:complexity:report && pnpm run ui:complexity:allowlist:check",
    "check:no-emoji": "node scripts/check-no-emoji.mjs",
    "flint": "pnpm run fix && pnpm run lint",
    "sanity": "pnpm run fix && pnpm run check",
    "check": "run-p lint type-check type-check:agent type-check:agent-control-ui test:silent architecture:boundary-scan agent:boundary-scan agent:smoke ui:complexity:ci knip:files check:no-emoji i18n:check i18n:guard",
    "check:silent": "pnpm run check",
    "maersk:smoke:puppeteer": "node scripts/maersk-puppeteer-smoke.mjs",
    "ai:loop:doctor": "bash scripts/ai/ralph-loop-doctor.sh",
    "ai:ralph": "bash scripts/ai/ralph.sh",
    "ai:loop:start": "bash scripts/ai/ralph-loop-start.sh",
    "ai:loop:plan": "bash scripts/ai/ralph-loop-plan.sh",
    "ai:loop:input": "bash scripts/ai/ralph-loop-make-input.sh",
    "ai:loop:exec": "bash scripts/ai/ralph-loop-exec.sh",
    "ai:loop:update": "bash scripts/ai/ralph-loop-update.sh",
    "ai:pr:feedback": "bash scripts/ai/github-pr-feedback.sh",
    "ai:wt-implement": "bash tools/worktrees/wt-implement.sh",
    "ai:skills:sync": "bash scripts/ai/sync-global-skills.sh",
    "agent:build": "pnpm --filter @container-tracker/agent run build:core",
    "agent:run": "pnpm --filter @container-tracker/agent run run",
    "agent:run:headless": "pnpm --filter @container-tracker/agent run run:headless",
    "agent:release": "pnpm --filter @container-tracker/agent run release",
    "agent:bundle": "pnpm --filter @container-tracker/agent run bundle",
    "agent:setup": "pnpm --filter @container-tracker/agent run setup",
    "agent:setup:docker": "pnpm --filter @container-tracker/agent run setup:docker",
    "agent:setup:wine": "pnpm --filter @container-tracker/agent run setup:wine",
    "agent:setup:native": "pnpm --filter @container-tracker/agent run setup:native",
    "agent:e2e:linux": "pnpm --filter @container-tracker/agent run e2e:linux",
    "agent:rebuild-restart:windows": "pnpm --filter @container-tracker/agent run rebuild-restart:windows",
    "agent:rebuild-restart:linux": "pnpm --filter @container-tracker/agent run rebuild-restart:linux",
    "rebuild-restart:linux": "pnpm run agent:rebuild-restart:linux",
    "supabase:start": "node ./scripts/db/worktree-db.mjs supabase-start",
    "supabase:stop": "node ./scripts/db/worktree-db.mjs supabase-stop",
    "supabase:status": "node ./scripts/db/worktree-db.mjs supabase-status",
    "supabase:status:env": "node ./scripts/db/worktree-db.mjs supabase-status-env",
    "supabase:reset": "node ./scripts/db/supabase-local-db.mjs reset",
    "supabase:migration:new": "npx supabase migration new",
    "supabase:db:diff": "node ./scripts/db/supabase-local-db.mjs diff",
    "supabase:gen-types": "yes | node ./scripts/db/supabase-local-db.mjs gen-types --lang typescript > src/shared/supabase/database.types.ts && pnpm run fix",
    "db:worktree:init": "node ./scripts/db/worktree-db.mjs worktree-init",
    "db:worktree:status": "node ./scripts/db/worktree-db.mjs worktree-status",
    "db:stage:ensure": "node ./scripts/db/worktree-db.mjs stage-ensure",
    "db:stage:status": "node ./scripts/db/worktree-db.mjs stage-status",
    "db:stage:refresh-local-snapshot": "node ./scripts/db/worktree-db.mjs stage-refresh-local-snapshot",
    "db:stage:rebuild": "node ./scripts/db/worktree-db.mjs stage-rebuild",
    "db:emancipate": "node ./scripts/db/worktree-db.mjs emancipate",
    "db:rejoin": "node ./scripts/db/worktree-db.mjs rejoin",
    "destroy-worktree": "node ./scripts/destroy-worktree.mjs",
    "db:prod:dump:data": "bash ./scripts/db/prod-dump-data.sh",
    "db:prod:pull:schema": "bash ./scripts/db/prod-pull-schema.sh",
    "db:local:restore:data": "bash ./scripts/db/local-restore-data.sh",
    "db:prod-to-local:sync:data": "bash ./scripts/db/prod-to-local-data.sh",
    "db:prod-to-local:sync:schema": "bash ./scripts/db/prod-to-local-schema.sh",
    "depgraph:dot": "node scripts/depgraph-columns.mjs",
    "dot": "pnpm run depgraph:dot && xdot dep-graph.dot",
    "knip": "knip",
    "knip:files": "knip --files --no-progress",
    "deps:marcus:update": "pnpm up \"@marcuscastelo/*\" -r --latest"
  },
  "dependencies": {
    "@msviderok/base-ui-solid": "1.0.0-beta.9",
    "@opentelemetry/api": "^1.9.0",
    "@solid-primitives/i18n": "^2.2.1",
    "@solidjs/router": "^0.15.0",
    "@solidjs/start": "^1.1.0",
    "@supabase/supabase-js": "^2.94.0",
    "archiver": "^7.0.1",
    "axios": "1.14.0",
    "lucide-solid": "^0.577.0",
    "solid-js": "^1.9.5",
    "vinxi": "^0.5.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@eslint/js": "^10.0.1",
    "@marcuscastelo/eslint-config": "^0.2.3",
    "@marcuscastelo/eslint-plugin": "^0.2.1",
    "@marcuscastelo/tsconfig": "^0.1.2",
    "@tailwindcss/vite": "^4.0.7",
    "@types/node": "^25.2.3",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitest/coverage-v8": "^3.2.2",
    "biome-plugin-no-type-assertion": "^1.0.2",
    "clsx": "^2.1.1",
    "dependency-cruiser": "^17.3.10",
    "electron": "^41.1.1",
    "esbuild": "^0.28.0",
    "eslint": "10",
    "eslint-plugin-solid": "^0.14.5",
    "graphviz": "^0.0.9",
    "knip": "^5.83.1",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.58.1",
    "postject": "1.0.0-alpha.6",
    "puppeteer": "^24.36.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "solid-toast": "^0.5.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.0.7",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-solid": "^2.11.11",
    "vitest": "^3.2.2"
  },
  "engines": {
    "node": ">=22"
  }
}
