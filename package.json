{
  "name": "example-with-tailwindcss",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vinxi dev",
    "build": "vinxi build",
    "start": "vinxi start",
    "electron:dev": "concurrently \"npm:dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:start": "electron .",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "@solidjs/router": "^0.15.0",
    "@solidjs/start": "^1.1.0",
    "solid-js": "^1.9.5",
    "vinxi": "^0.5.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.7",
    "playwright": "^1.58.1",
    "puppeteer": "^24.36.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "tailwindcss": "^4.0.7",
    "concurrently": "^8.0.0",
    "wait-on": "^7.0.0",
    "electron": "^26.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.marcus.container-tracker",
    "files": [
      "dist/**",
      "build/**",
      "electron/**",
      "package.json"
    ]
  },
  "engines": {
    "node": ">=22"
  }
}
