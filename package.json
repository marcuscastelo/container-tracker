{
  "name": "example-with-tailwindcss",
  "type": "module",
  "imports": {
    "#container-tracker-eslint-plugin": "./scripts/eslint-plugin/eslint-plugin-container-tracker.mjs"
  },
  "scripts": {
    "dev": "bash scripts/dev/dev.sh",
    "dev:server": "vinxi dev",
    "build": "vinxi build",
    "start": "vinxi start",
    "type-check": "tsc -p tsconfig.app.json --noEmit --skipLibCheck",
    "type-check:agent": "tsc -p tools/agent/tsconfig.json --noEmit --skipLibCheck",
    "test": "vitest run",
    "test:playwright": "playwright test",
    "i18n:check": "node scripts/lint/check-i18n-keys.mjs",
    "i18n:enforce": "node scripts/lint/enforce-i18n-no-hardcoded.mjs",
    "fix": "pnpm exec biome format --write . --format-with-errors true && pnpm exec biome check . --write --max-diagnostics=1000 --no-errors-on-unmatched",
    "lint": "pnpm exec biome check . --max-diagnostics=1000 --no-errors-on-unmatched && pnpm exec eslint --ext .ts,.tsx . --max-warnings=0",
    "architecture:boundary-scan": "node scripts/lint/architecture-boundary-scan.mjs",
    "lint:no-iife:error-smoke": "node scripts/eslint-plugin/no-iife-in-jsx-error-smoke.mjs",
    "ui:complexity:report": "node scripts/lint/ui-complexity-report.mjs",
    "ui:complexity:report:write": "node scripts/lint/ui-complexity-report.mjs --write",
    "ui:complexity:lint:soft": "node scripts/lint/ui-complexity-report.mjs",
    "ui:complexity:allowlist:check": "node scripts/lint/ui-complexity-allowlist-check.mjs",
    "ui:complexity:ci": "pnpm run ui:complexity:report && pnpm run ui:complexity:allowlist:check",
    "check:no-emoji": "node scripts/lint/check-no-emoji.mjs",
    "flint": "pnpm run fix && pnpm run lint",
    "check": "run-p lint type-check type-check:agent test architecture:boundary-scan ui:complexity:ci knip:files check:no-emoji",
    "maersk:smoke:puppeteer": "node scripts/integration/maersk-puppeteer-smoke.mjs",
    "ai:loop:doctor": "bash scripts/ai/ralph-loop-doctor.sh",
    "ai:loop:start": "bash scripts/ai/ralph-loop-start.sh",
    "ai:loop:plan": "bash scripts/ai/ralph-loop-plan.sh",
    "ai:loop:input": "bash scripts/ai/ralph-loop-make-input.sh",
    "ai:loop:exec": "bash scripts/ai/ralph-loop-exec.sh",
    "ai:loop:update": "bash scripts/ai/ralph-loop-update.sh",
    "ai:pr:feedback": "bash scripts/ai/github-pr-feedback.sh",
    "ai:wt-implement": "bash tools/worktrees/wt-implement.sh",
    "ai:skills:sync": "bash scripts/ai/sync-global-skills.sh",
    "agent:build": "pnpm exec tsc -p tools/agent/tsconfig.json",
    "agent:run": "pnpm run agent:build && bash scripts/agent/run-linux.sh",
    "agent:release": "pnpm run agent:build && node tools/agent/dist/tools/agent/build-release.js",
    "agent:bundle": "pnpm run agent:release && node tools/agent/dist/tools/agent/bundle-release.js",
    "agent:setup": "node scripts/agent/setup-installer.mjs",
    "agent:setup:docker": "node scripts/agent/setup-installer.mjs --mode=docker",
    "agent:setup:wine": "node scripts/agent/setup-installer.mjs --mode=wine",
    "agent:setup:native": "node scripts/agent/setup-installer.mjs --mode=native",
    "agent:e2e:linux": "pnpm run agent:build && node scripts/agent/e2e-install-linux.mjs",
    "agent:rebuild-restart:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/agent/rebuild-reinstall.ps1",
    "agent:rebuild-restart:linux": "bash scripts/agent/rebuild-restart-linux.sh",
    "rebuild-restart:linux": "pnpm run agent:rebuild-restart:linux",
    "supabase:gen-types": "yes | npx supabase gen types typescript --project-id kremuphdcxwgceravqfh > src/shared/supabase/database.types.ts && pnpm run fix",
    "knip": "knip",
    "knip:files": "knip --files --no-progress",
    "deps:marcus:update": "pnpm up \"@marcuscastelo/*\" -r --latest"
  },
  "dependencies": {
    "@msviderok/base-ui-solid": "1.0.0-beta.9",
    "@opentelemetry/api": "^1.9.0",
    "@solidjs/router": "^0.15.0",
    "@solidjs/start": "^1.1.0",
    "@supabase/supabase-js": "^2.94.0",
    "archiver": "^7.0.1",
    "axios": "^1.13.4",
    "i18next": "^25.8.1",
    "lucide-solid": "^0.577.0",
    "solid-js": "^1.9.5",
    "vinxi": "^0.5.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@eslint/js": "^10.0.1",
    "@marcuscastelo/eslint-config": "^0.4.0",
    "@marcuscastelo/eslint-plugin": "^0.3.0",
    "@marcuscastelo/tsconfig": "^0.2.0",
    "@tailwindcss/vite": "^4.0.7",
    "@types/i18next": "^13.0.0",
    "@types/node": "^25.2.3",
    "@typescript-eslint/parser": "^8.55.0",
    "biome-plugin-no-type-assertion": "^1.0.2",
    "clsx": "^2.1.1",
    "eslint": "10",
    "eslint-plugin-solid": "^0.14.5",
    "knip": "^5.83.1",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.58.1",
    "puppeteer": "^24.36.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "solid-toast": "^0.5.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.0.7",
    "typescript": "^5.9.3",
    "vitest": "^3.2.2"
  },
  "engines": {
    "node": ">=22"
  }
}
