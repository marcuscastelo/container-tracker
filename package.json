{
  "name": "example-with-tailwindcss",
  "version": "0.0.0",
  "description": "Container Tracker",
  "author": "",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vinxi dev",
    "build": "vinxi build",
    "start": "vinxi start",
    "electron:dev": "concurrently \"npm:dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:start": "electron .",
    "start-server": "node server/index.js",
    "start-server:port": "PORT=4000 node server/index.js",
    "start-maersk-server": "node server/maersk-server.cjs",
    "build:maersk:win": "pkg server/maersk-server.cjs --targets node22-win-x64 --output dist/maersk-server.exe",
    "electron:build": "npm run build && electron-builder",
    "electron:build:win": "pnpm run build:maersk:win && pnpm run build && pnpm exec electron-builder --win --x64 --publish never"
  },
  "dependencies": {
    "express": "^4.22.1",
    "puppeteer": "^24.36.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "pkg": "^5.10.9",
    "@tailwindcss/vite": "^4.0.7",
    "concurrently": "^8.0.0",
    "electron": "^26.0.0",
    "electron-builder": "^24.0.0",
    "playwright": "^1.58.1",
    "tailwindcss": "^4.0.7",
    "wait-on": "^7.0.0"
  },
  "build": {
    "appId": "com.marcus.container-tracker",
    "productName": "Container Tracker",
    "files": [
      "dist/**",
      "build/**",
      ".vinxi/build/**",
      "electron/**",
      "package.json"
    ],
    "asarUnpack": [
      ".vinxi/build/**",
      "build/**"
    ],
    "extraResources": [
      {
        "from": "server",
        "to": "server",
        "filter": [
          "**/*"
        ]
      }
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/icon.png"
    }
  },
  "engines": {
    "node": ">=22"
  }
}
