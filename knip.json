{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "tags": ["-lintignore"],
  "workspaces": {
    ".": {
      "entry": [
        "src/app.{js,ts,tsx}",
        "src/entry-client.{js,ts,tsx}",
        "src/entry-server.{js,ts,tsx}",
        "src/routes/**/*.{js,ts,tsx}",
        "scripts/**/*.{js,ts,tsx}"
      ],
      "project": ["src/**/*.{js,ts,tsx}", "scripts/**/*.{js,ts,tsx}"]
    },
    "apps/agent": {
      "entry": [
        "src/agent.ts",
        "src/supervisor.ts",
        "src/updater.ts",
        "src/electron/main.ts",
        "src/electron/preload.cjs",
        "src/renderer/main.tsx",
        "src/bootstrap/**/*.ts",
        "src/cli/**/*.ts",
        "src/runtime/alias-loader.ts",
        "src/runtime/register-alias-loader.ts",
        "src/build-release.ts",
        "src/bundle-release.ts"
      ],
      "project": ["src/**/*.{js,ts,tsx,cjs,d.ts}"],
      "ignoreFiles": [
        "src/config/resolve-agent-public-paths.ts",
        "src/renderer/AgentControlApp.tsx"
      ]
    }
  },
  "ignore": [
    "src/shared/supabase/database.types.ts",
    "src/routes/**/*",
    "src/i18n/**/*",
    "src/modules/tracking/infrastructure/carriers/fetchers/maersk.puppeteer.fetcher.ts",
    "src/shared/ui/layout/Stack.tsx"
  ],
  "ignoreDependencies": [
    "@msviderok/base-ui-solid",
    "@opentelemetry/api",
    "@eslint/js",
    "@tailwindcss/vite",
    "@types/i18next",
    "biome-plugin-no-type-assertion",
    "playwright",
    "solid-toast",
    "tailwind-merge",
    "tailwindcss"
  ],
  "ignoreBinaries": ["supabase"],
  "biome": true,
  "eslint": true,
  "tailwind": true,
  "tsx": true
}
