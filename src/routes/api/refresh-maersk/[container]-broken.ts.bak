import fs from 'fs'
import path from 'path'

// NOTE: We no longer parse curl files or rely on saved curl content. The
// browser-run request is captured directly via CDP (Network.request/response)
// and that captured request URL/headers are used for diagnostics and writing
// the output. This makes the route independent of saved .txt curl files.

export async function GET({ params, request }: any) {
  try {
    const container = params?.container
    if (!container) return new Response(JSON.stringify({ error: 'container param required' }), { status: 400 })

    const projectRoot = process.cwd()
    const collectionsDir = path.join(projectRoot, 'collections')
    if (!fs.existsSync(collectionsDir)) return new Response(JSON.stringify({ error: 'collections directory not found' }), { status: 500 })

    // Ensure provider directory exists and compute JSON path for the container
    const provider = 'maersk'
    const providerDir = path.join(collectionsDir, provider)
    if (!fs.existsSync(providerDir)) return new Response(JSON.stringify({ error: 'maersk collections directory not found' }), { status: 500 })
    const json = path.join(providerDir, `${container}.json`)
    // ensure file exists (create empty if missing)
    if (!fs.existsSync(json)) {
      try { fs.writeFileSync(json, '{}', 'utf-8') } catch (e) { /* ignore */ }
    }

    // Try to use puppeteer-extra + stealth to evade bot detection (undetected chrome)
    // Require packages: puppeteer, puppeteer-extra, puppeteer-extra-plugin-stealth
    let puppeteerExtra: any = null
    let Puppeteer: any = null
    try {
      const pe = await import('puppeteer-extra').catch(() => null)
      const stealthMod = await import('puppeteer-extra-plugin-stealth').catch(() => null)
      Puppeteer = await import('puppeteer').catch(() => null)
      if (!pe || !stealthMod || !Puppeteer) {
        return new Response(JSON.stringify({ error: 'puppeteer-extra or dependencies not installed', hint: 'npm i -D puppeteer puppeteer-extra puppeteer-extra-plugin-stealth' }), { status: 500 })
      }
      puppeteerExtra = (pe as any).default || pe
      const Stealth = (stealthMod as any).default || stealthMod
      puppeteerExtra.use(Stealth())
    } catch (e) {
      return new Response(JSON.stringify({ error: 'puppeteer import error', details: String(e), hint: 'npm i -D puppeteer puppeteer-extra puppeteer-extra-plugin-stealth' }), { status: 500 })
    }

    // Launch browser. For debugging we show the UI; set env HEADLESS=1 to run headless
    const url = request ? new URL(request.url) : null
    const qHeadless = url ? url.searchParams.get('headless') : null
    const headless = qHeadless !== null ? (qHeadless === '1' || qHeadless === 'true') : (process.env.HEADLESS === '1' || process.env.HEADLESS === 'true')
    const launchArgs: string[] = ['--no-sandbox', '--disable-setuid-sandbox', '--disable-blink-features=AutomationControlled']

    // helper: locate a Chrome/Chromium executable on the host
    function findSystemChrome(): string | null {
      const envPath = process.env.CHROME_PATH || process.env.CHROMIUM_PATH
      if (envPath && fs.existsSync(envPath)) return envPath
      const platform = process.platform
      const candidates: string[] = []
      if (platform === 'win32') {
        const programFiles = process.env['PROGRAMFILES'] || 'C:\\Program Files'
        const programFilesx86 = process.env['PROGRAMFILES(X86)'] || 'C:\\Program Files (x86)'
        candidates.push(path.join(programFiles, 'Google', 'Chrome', 'Application', 'chrome.exe'))
        candidates.push(path.join(programFilesx86, 'Google', 'Chrome', 'Application', 'chrome.exe'))
        candidates.push(path.join(programFiles, 'Chromium', 'Application', 'chrome.exe'))
      } else if (platform === 'darwin') {
        candidates.push('/Applications/Google Chrome.app/Contents/MacOS/Google Chrome')
        candidates.push('/Applications/Chromium.app/Contents/MacOS/Chromium')
      } else {
        // linux
        candidates.push('/usr/bin/google-chrome')
        candidates.push('/usr/bin/google-chrome-stable')
        candidates.push('/usr/bin/chromium-browser')
        candidates.push('/usr/bin/chromium')
        candidates.push('/snap/bin/chromium')
      }
      for (const c of candidates) if (fs.existsSync(c)) return c
      return null
    }

    let browser: any
    try {
      const puppeteer = (Puppeteer as any).default || Puppeteer
      // try puppeteer's bundled executable path first (may not exist if download was skipped)
      let executablePath: string | undefined
      try {
        if (typeof puppeteer.executablePath === 'function') executablePath = puppeteer.executablePath()
      } catch (e) {
        // ignore
      }
      if (!executablePath || !fs.existsSync(executablePath)) {
        const systemPath = findSystemChrome()
        if (systemPath) executablePath = systemPath
      }
      const launchOpts: any = { headless: !!headless, args: launchArgs }
      // allow overriding via query param ?userDataDir=... or env vars CHROME_USER_DATA_DIR/USER_DATA_DIR
      let userDataDir = url ? url.searchParams.get('userDataDir') : null
      if (!userDataDir) userDataDir = process.env.CHROME_USER_DATA_DIR || process.env.USER_DATA_DIR || null
      if (userDataDir && fs.existsSync(userDataDir)) launchOpts.userDataDir = userDataDir
      if (executablePath) launchOpts.executablePath = executablePath
      browser = await puppeteerExtra.launch(launchOpts)
    } catch (e) {
      console.error('maersk-refresh: puppeteer launch failed', e)
      return new Response(JSON.stringify({ error: 'puppeteer launch failed', details: String(e), hint: 'Install Chrome/Chromium or ensure puppeteer downloaded browsers. Set CHROME_PATH to a Chrome binary path.' }), { status: 500 })
    }
    const page = await browser.newPage()

    // mimic common real user environment
    try {
      await page.setUserAgent('Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/116.0.0.0 Safari/537.36')
      await page.setExtraHTTPHeaders({ 'Accept-Language': 'en-US,en;q=0.9' })
      await page.evaluateOnNewDocument(() => {
        // pass the webdriver check
        Object.defineProperty(navigator, 'webdriver', { get: () => false })
        // mock plugins and languages
        Object.defineProperty(navigator, 'languages', { get: () => ['en-US', 'en'] })
        // @ts-ignore
        window['chrome'] = { runtime: {} }
      })
      // Inject instrumentation to capture outgoing requests and responses
      try {
        await page.exposeFunction('__puppeteer_reportOutgoing', (info: any) => {
          // noop - notifications will be captured by page __outgoingRequests array
        })
        await page.evaluateOnNewDocument(`(function(){
          try{
            window.__outgoingRequests = [];
            window.__outgoingResponses = [];
            const origFetch = window.fetch.bind(window);
            window.fetch = async function(input, init){
              try{
                const url = typeof input === 'string' ? input : (input && input.url) || '';
                const info = { url, init };
                window.__outgoingRequests.push(info);
                if (window.__puppeteer_reportOutgoing) try { window.__puppeteer_reportOutgoing(info) } catch(e){}
                const res = await origFetch(input, init);
                try{ const clone = res.clone(); const text = await clone.text(); window.__outgoingResponses.push({ url, status: res.status, body: text }); } catch(e){}
                return res;
              }catch(e){ return origFetch(input, init); }
            };
            (function(){
              const origOpen = XMLHttpRequest.prototype.open;
              const origSend = XMLHttpRequest.prototype.send;
              XMLHttpRequest.prototype.open = function(method, url){ this.__xhr_method = method; this.__xhr_url = url; return origOpen.apply(this, arguments); };
              XMLHttpRequest.prototype.send = function(body){ try{ const xhr = this; const url = xhr.__xhr_url; const method = xhr.__xhr_method; const onload = function(){ try{ const status = xhr.status; const text = xhr.responseText; window.__outgoingRequests.push({ url, method, body }); window.__outgoingResponses.push({ url, status, body: text }); } catch(e){} }; xhr.addEventListener('load', onload); }catch(e){} return origSend.apply(this, arguments); };
            })();
            try{ const origBeacon = navigator.sendBeacon.bind(navigator); navigator.sendBeacon = function(url, data){ try{ window.__outgoingRequests.push({ url, method: 'BEACON', body: data }); } catch(e){} return origBeacon(url, data); } } catch(e){}
          }catch(e){}
        })()`)
      } catch (e) {
        console.debug('maersk-refresh: inject capture failed', e)
      }
    } catch (e) {
      console.debug('maersk-refresh: user-agent/setup apply failed', e)
    }

    const trackingUrl = `https://www.maersk.com/tracking/${container}`
    console.debug('maersk-refresh: navigating to', trackingUrl)

    // Create a CDP session to capture network responses (DevTools-like). Attach
    // the listener before navigation so we capture early XHR/fetch requests the
    // page issues.
    let cdpClient: any = null
    try {
      cdpClient = await (page.target() as any).createCDPSession()
      await cdpClient.send('Network.enable')
    } catch (e) {
      console.debug('maersk-refresh: could not create CDP session', String(e))
      cdpClient = null
    }

    // Prepare to capture the response via CDP. We no longer rely on a saved
    // curl URL; the request URL will be discovered from CDP request events.
    console.debug('maersk-refresh: waiting for network response for container', container)
    let fetchResult: any = null

    let lastReqInfo: any = null
    if (cdpClient) {
      try {
        // Attach CDP listeners to all existing and future targets (pages, frames,
        // service workers) so we don't miss requests initiated elsewhere.
        const sessions: Array<{ target: any; session: any; remove: () => void }> = []
        let resolveFunc: ((v: any) => void) | null = null

        const attachToTarget = async (target: any) => {
          try {
            const sess = await target.createCDPSession()
            await sess.send('Network.enable')

            const reqMap: Map<string, any> = new Map()

            const onReq = (evt: any) => {
              try {
                const r = evt.request
                if (r && r.url) {
                  const info = { url: r.url, method: r.method, headers: r.headers, postData: r.postData }
                  reqMap.set(evt.requestId, info)
                  lastReqInfo = info
                }
              } catch (e) {}
            }

            const onResp = async (event: any) => {
              try {
                const u = event.response && event.response.url
                if (u && u.includes('/synergy/tracking/') && u.includes(String(container))) {
                  try {
                    const body = await sess.send('Network.getResponseBody', { requestId: event.requestId })
                    let text = body.base64Encoded ? Buffer.from(body.body, 'base64').toString('utf8') : body.body
                    const reqInfo = reqMap.get(event.requestId) || null

                    let telemetry: string | null = null
                    try {
                      telemetry = await page.evaluate(() => {
                        try {
                          const b = (window as any).bmak
                          if (b && typeof b.get_telemetry === 'function') return b.get_telemetry()
                        } catch (e) {}
                        return null
                      })
                    } catch (e) {
                      telemetry = null
                    }
                    const cookies = await page.cookies()
                    const ua = await page.evaluate(() => navigator.userAgent)

                    const diagnostics = { telemetry, cookies, userAgent: ua }

                    try {
                      const json = JSON.parse(text)
                      // cleanup
                      for (const s of sessions) { try { s.remove() } catch (e) {} }
                      if (resolveFunc) resolveFunc({ ok: true, status: event.response.status, json, request: reqInfo, diagnostics })
                      return
                    } catch (e) {
                      for (const s of sessions) { try { s.remove() } catch (e) {} }
                      if (resolveFunc) resolveFunc({ ok: true, status: event.response.status, text, request: reqInfo, diagnostics })
                      return
                    }
                  } catch (e) {
                    for (const s of sessions) { try { s.remove() } catch (e) {} }
                    if (resolveFunc) resolveFunc({ ok: false, error: String(e) })
                    return
                  }
                }
              } catch (e) {}
            }

            sess.on('Network.requestWillBeSent', onReq)
            sess.on('Network.responseReceived', onResp)

            sessions.push({ target, session: sess, remove: () => { try { sess.off('Network.requestWillBeSent', onReq); sess.off('Network.responseReceived', onResp) } catch (e) {} } })
          } catch (e) {
            // ignore target attach failures
          }
        }

        // attach to existing targets
        const existing = browser.targets()
        for (const t of existing) {
          attachToTarget(t).catch(() => {})
        }

        // attach to future targets
        const onTarget = (t: any) => { attachToTarget(t).catch(() => {}) }
        try { browser.on('targetcreated', onTarget) } catch (e) {}

        // Wait for a response (navigate after listeners attached)
        fetchResult = await new Promise<any>(async (resolve) => {
          resolveFunc = resolve
          try {
            page.setDefaultNavigationTimeout(60000)
            await page.goto(trackingUrl, { waitUntil: 'networkidle', timeout: 45000 }).catch(() => {})
          } catch (e) {
            console.debug('maersk-refresh: page.goto (cdp-multi) failed', String(e))
          }

          // fallback timeout
          setTimeout(() => {
            try {
              for (const s of sessions) s.remove()
              try { browser.off('targetcreated', onTarget) } catch (e) {}
            } catch (e) {}
            if (resolveFunc) resolveFunc(null)
          }, 30000)
        })
      } catch (e) {
        console.debug('maersk-refresh: cdp capture failed', String(e))
      }
    }

    // If CDP didn't capture the response, fall back to waiting for the response
    // via puppeteer's API, then try server-side fetch as a last resort.
    if (!fetchResult) {
      try {
        // verify navigation happened; if not, try to load page
        try {
          const cur = page.url()
          console.debug('maersk-refresh: page url after goto:', cur)
          if (!cur || !cur.includes('maersk.com')) {
            console.debug('maersk-refresh: page did not navigate to maersk, retrying with domcontentloaded')
            try {
              await page.goto(trackingUrl, { waitUntil: 'domcontentloaded', timeout: 60000 })
            } catch (e) {
              console.debug('maersk-refresh: retry page.goto failed', String(e))
            }
          }
        } catch (e) {
          console.debug('maersk-refresh: error checking page.url()', String(e))
        }

        // wait for bmak
        try {
          await page.waitForFunction(() => (window as any).bmak && typeof (window as any).bmak.get_telemetry === 'function', { timeout: 20000 })
        } catch (e) {
          console.debug('maersk-refresh: bmak not found within timeout; continuing')
        }

        // Wait for the response that contains the tracking path and the container id.
        const resp = await page.waitForResponse(
          (r: any) => {
            try {
              const u = r.url()
              return u.includes('/synergy/tracking/') && u.includes(String(container))
            } catch (e) {
              return false
            }
          },
          { timeout: 20000 }
        )

        const status = resp.status()
        const headers = resp.headers() || {}
        const contentType = (headers['content-type'] || '') as string
        const bodyText = await resp.text()
        if (contentType.includes('application/json')) {
          try {
            const json = JSON.parse(bodyText)
            fetchResult = { ok: true, status, json }
          } catch (e) {
            fetchResult = { ok: true, status, text: bodyText }
          }
        } else {
          fetchResult = { ok: true, status, text: bodyText }
        }
      } catch (err) {
        console.debug('maersk-refresh: did not capture network response directly', String(err))
        // We DO NOT perform a server-side fetch anymore. Instead, collect
        // diagnostics (telemetry, cookies, last request info) and either
        // hold the browser open for manual interaction or return an error so
        // the caller can retry with a user-data-dir that already has Akamai
        // cookies.
        let telemetry: string | null = null
        try {
          telemetry = await page.evaluate(() => {
            try {
              const b = (window as any).bmak
              if (b && typeof b.get_telemetry === 'function') return b.get_telemetry()
            } catch (e) {}
            return null
          })
        } catch (e) {
          console.debug('maersk-refresh: error reading telemetry from page', e)
        }

        const allCookies = await page.cookies()
        const relevant = allCookies.filter((c: any) => c.domain && (c.domain.includes('maersk.com') || c.domain.includes('api.maersk.com')))

        // Attempt to read any captures injected into the page (fetch/XHR wrappers)
        let pageCaptures: any = null
        try {
          pageCaptures = await page.evaluate(() => ({ requests: (window as any).__outgoingRequests || [], responses: (window as any).__outgoingResponses || [] }))
        } catch (e) {
          pageCaptures = null
        }

        const diagnostics = {
          telemetry,
          cookies: relevant,
          lastRequest: lastReqInfo || (pageCaptures && pageCaptures.requests && pageCaptures.requests.length ? pageCaptures.requests[pageCaptures.requests.length - 1] : null),
          pageCaptures
        }

        // If the injected capture recorded the response body for the tracking
        // request, use it as the fetchResult (this is equivalent to DevTools).
        try {
          if (pageCaptures && Array.isArray(pageCaptures.responses)) {
            const match = pageCaptures.responses.find((r: any) => r && typeof r.url === 'string' && r.url.includes('/synergy/tracking/') && r.url.includes(String(container)))
            if (match) {
              try {
                const bodyText = match.body
                if (bodyText && bodyText.startsWith('<')) {
                  fetchResult = { ok: true, status: match.status || 200, text: bodyText }
                } else {
                  try {
                    const j = JSON.parse(bodyText)
                    fetchResult = { ok: true, status: match.status || 200, json: j }
                  } catch (e) {
                    fetchResult = { ok: true, status: match.status || 200, text: bodyText }
                  }
                }
              } catch (e) {
                // ignore parse errors and continue to write diagnostics
              }
            }
          }
        } catch (e) {
          // ignore
        }

        // write diagnostics now so the operator can inspect
        try {
          const metaPath = json + '.devtools.json'
          const meta = { request: lastReqInfo || null, diagnostics, status: null, source: 'cdp-capture-missing' }
          fs.writeFileSync(metaPath, JSON.stringify(meta, null, 2), 'utf-8')
          console.log(`refresh-maersk: wrote diagnostics ${path.relative(projectRoot, metaPath)}`)
        } catch (e) {
          console.debug('maersk-refresh: could not write diagnostics', e)
        }

        // If caller requested to hold the browser open for manual action, do so.
        const hold = url ? url.searchParams.get('hold') === '1' : false
        if (hold) {
          console.log('refresh-maersk: holding browser open for manual interaction')
          // leave browser open and return info to caller
          return new Response(JSON.stringify({ ok: false, reason: 'cdp-miss-held', diagnosticsPath: path.relative(projectRoot, json + '.devtools.json') }), { status: 202 })
        }

        // otherwise return an error indicating CDP did not capture the expected response
        fetchResult = { ok: false, error: 'cdp did not capture tracking response', diagnostics }
      }
    }

    // close browser
    try { if (browser) await browser.close() } catch (e) { console.debug('maersk-refresh: browser close failed', e) }

    if (!fetchResult || !fetchResult.ok) {
      return new Response(JSON.stringify({ error: 'fetch failed in browser', details: fetchResult }), { status: 502 })
    }

    // write result to JSON file (pretty print if JSON). Also write a .devtools.json
    // diagnostics file when available (request headers, telemetry, cookies).
    try {
      let outText = ''
      if (fetchResult.json) outText = JSON.stringify(fetchResult.json, null, 4)
      else if (fetchResult.text) outText = String(fetchResult.text)
      else outText = JSON.stringify(fetchResult)
      fs.writeFileSync(json, outText, 'utf-8')
      console.log(`refresh-maersk: wrote ${path.relative(projectRoot, json)} (${outText.length} bytes)`)

      // write diagnostics if available
      if (fetchResult.request || fetchResult.diagnostics) {
        const metaPath = json + '.devtools.json'
        const meta = {
          request: fetchResult.request || null,
          diagnostics: fetchResult.diagnostics || null,
          status: fetchResult.status || null,
          source: 'cdp-capture'
        }
        fs.writeFileSync(metaPath, JSON.stringify(meta, null, 2), 'utf-8')
        console.log(`refresh-maersk: wrote diagnostics ${path.relative(projectRoot, metaPath)}`)
      }
    } catch (err) {
      return new Response(JSON.stringify({ error: 'write failed', details: String(err) }), { status: 500 })
    }

    return new Response(JSON.stringify({ ok: true, updatedPath: path.relative(projectRoot, json) }), { status: 200 })
  } catch (err: any) {
    console.error('refresh-maersk error', err)
    return new Response(JSON.stringify({ error: String(err) }), { status: 500 })
  }
}

export const POST = GET
